{
	"manifest_version": 3,
	"name": "Roll20 Roll Server Companion",
	"version": "1.0",

	"permissions": [
		"storage"
	],

	"host_permissions": [
        "https://lordashes.ca:3000/*"
    ],

    "background": {
        "service_worker": "background.js"
    },

	"content_scripts": [
		{
			"matches": ["https://app.roll20.net/editor/*"],
			"js": ["injection.js"]
		}
	],
	
	"action": {
		"default_icon": {
			"16": "icon.png",
			"32": "icon32.png",
			"48": "icon48.png",
			"128": "icon128.png"
		}
	},

	"icons": {
		"16": "icon.png",
		"32": "icon32.png",
		"48": "icon48.png",
		"128": "icon128.png"
	}
}
